# Label Padegha Sabh — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env.

# AI APIs
GEMINI_API_KEY=your_gemini_api_key_here
USDA_API_KEY=your_usda_api_key_here

# Server
FLASK_DEBUG=false
LPS_SERVER=fastapi
LPS_HOST=0.0.0.0
LPS_PORT=5000
FASTAPI_PORT=8000
LPS_CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:8000,http://127.0.0.1:8000

# PostgreSQL
DATABASE_URL=postgresql://lps:lps_dev_password@localhost:5432/lps

# MongoDB
MONGODB_URL=mongodb://localhost:27017/lps

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Auth
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limits
GUEST_DAILY_SCAN_LIMIT=5
FREE_DAILY_SCAN_LIMIT=20
